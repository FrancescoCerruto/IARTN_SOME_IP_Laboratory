#!/bin/bash

set -e

if [ "$LAB_LOADED" != "true" ]; then
	source 0_lab_setenv
fi

if [ ! -d "$GENERATORS_FOLDER/commonapi-core-generator" ]; then

unzip -o commonapi-core-generator.zip -d $GENERATORS_FOLDER
cat << EOF | sudo tee /usr/local/bin/commonapi-core > /dev/null
#!/bin/bash
java -jar $GENERATORS_FOLDER/commonapi-core-generator/plugins/org.eclipse.equinox.launcher_*.jar \\
    -application org.genivi.commonapi.console.application \\
    -nosplash \\
    -data /tmp/commonapi_core_work \\
    -sk \\
    -dest src-gen/core \\
    "\$@"
EOF

sudo chmod +x /usr/local/bin/commonapi-core

fi

if [ ! -d "$GENERATORS_FOLDER/commonapi-dbus-generator" ]; then

unzip -o commonapi-dbus-generator.zip -d $GENERATORS_FOLDER
cat << EOF | sudo tee /usr/local/bin/commonapi-dbus > /dev/null
