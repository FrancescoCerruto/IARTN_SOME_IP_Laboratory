    -application org.genivi.commonapi.console.application \\
    -nosplash \\
    -data /tmp/commonapi_dbus_work \\
    -dest src-gen/dbus \\
    "\$@"
EOF

sudo chmod +x /usr/local/bin/commonapi-dbus

fi

if [ ! -d "$GENERATORS_FOLDER/commonapi-someip-generator" ]; then

unzip -o commonapi-someip-generator.zip -d $GENERATORS_FOLDER
cat << EOF | sudo tee /usr/local/bin/commonapi-someip > /dev/null
#!/bin/bash
java -jar $GENERATORS_FOLDER/commonapi-someip-generator/plugins/org.eclipse.equinox.launcher_*.jar \\
